<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_securetrack"
        android:scaleType="centerCrop" />

    <!-- Dark Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#77000000" />

    <!-- Foreground Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_securetrack_shield"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SecureTrack"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/taglineText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Cybersecurity Risk Assessment"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#D1C4E9"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Evaluate your daily security habits, receive a risk score, and get practical recommendations to improve your digital safety."
            android:textSize="16sp"
            android:textColor="#EDE7F6"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="36dp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Assessment"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_button"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="6dp"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</FrameLayout>